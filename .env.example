# Gmail credentials
# GMAIL_APP_PASSWORD must be a Gmail App Password (not your login password)
# Generate at: Google Account > Security > 2-Step Verification > App passwords
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Email content (fixed for all sends)
EMAIL_SUBJECT=
# Path to a .txt file containing the email body (supports multiline)
EMAIL_BODY_PATH=

# RESUME_PATH must be an absolute path to a real PDF file on disk
RESUME_PATH=

# Comma-separated list of additional file paths to attach (absolute paths)
ATTACHMENTS=

PORT=3000
